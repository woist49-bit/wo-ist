VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
# Web-Push: oeffentlicher VAPID-Key (mit `npx web-push generate-vapid-keys` erzeugen).
# Nicht geheim. Der PRIVATE Gegenpart gehoert NICHT hierher, sondern in ein Supabase-Secret.
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key-here
